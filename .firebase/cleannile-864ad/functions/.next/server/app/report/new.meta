{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/report/layout,_N_T_/report/new/layout,_N_T_/report/new/page,_N_T_/report/new"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/report/new/__PAGE__",
    "/report/new",
    "/report",
    "/_index",
    "/_head"
  ]
}